# Copy this file to ".env" (or ".env.production") and adjust as needed.
#
# NOTE: Vite inlines VITE_* variables at BUILD time, so this must be set
# before `npm run build` for the value to reach the production bundle.

# Base URL of the Express backend API.
# - Local development: optional. If omitted, the app falls back to
#   http://localhost:5000 (the backend this project ships with).
# - Production: REQUIRED. A production build with VITE_API_URL unset throws a
#   clear error at startup instead of silently pointing at localhost.
# Example:
VITE_API_URL=http://localhost:5000
