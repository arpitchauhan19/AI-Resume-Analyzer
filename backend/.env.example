# Copy this file to ".env" and adjust the values for your environment.
#
# In development every value below has a sensible localhost default, so the
# backend runs with zero configuration. In production (NODE_ENV=production)
# the localhost defaults are NOT applied: PARSER_SERVICE_URL and CORS_ORIGIN
# MUST be set explicitly or the server refuses to start.

# Port the HTTP server listens on.
PORT=5000

# Node environment: development | production
NODE_ENV=development

# MongoDB connection string. Optional/best-effort: if unreachable the API still
# runs and simply skips upload-metadata persistence.
MONGODB_URI=mongodb://127.0.0.1:27017/ai-resume-analyzer

# Comma-separated list of origins allowed by CORS.
# REQUIRED in production (set it to your deployed frontend origin(s)).
# Example for the Vite dev server:
CORS_ORIGIN=http://localhost:5173

# Maximum allowed upload size in bytes (default 5 MB).
MAX_UPLOAD_SIZE=5242880

# Directory (relative to backend root) where uploaded files are stored.
UPLOAD_DIR=src/uploads

# Base URL of the Python FastAPI resume parser service.
# REQUIRED in production (set it to the parser's deployed URL).
PARSER_SERVICE_URL=http://localhost:8000

# Timeout (in milliseconds) for requests to the parser service.
# Must be a positive number; invalid values fall back to 30000.
PARSER_TIMEOUT_MS=30000
