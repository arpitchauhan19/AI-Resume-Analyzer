# Copy this file to ".env" and adjust the values for your environment.

# Port the HTTP server listens on.
PORT=5000

# Node environment: development | production
NODE_ENV=development

# MongoDB connection string.
MONGODB_URI=mongodb://127.0.0.1:27017/ai-resume-analyzer

# Comma-separated list of origins allowed by CORS.
# Example for the Vite dev server:
CORS_ORIGIN=http://localhost:5173

# Maximum allowed upload size in bytes (default 5 MB).
MAX_UPLOAD_SIZE=5242880

# Directory (relative to backend root) where uploaded files are stored.
UPLOAD_DIR=src/uploads
